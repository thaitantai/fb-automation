{
  "name": "fb-automation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm run db && dotenv -e .env turbo run dev",
    "dev:db": "pnpm packages/database",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db": "pnpm run db:up",
    "db:studio": "pnpm --filter @fb-automation/database db:studio"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "turbo": "^1.13.0",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.5"
}